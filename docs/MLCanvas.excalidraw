      "isDeleted": false,
      "boundElements": [],
      "updated": 1773880977551,
      "link": null,
      "locked": false,
      "text": "Dataset público de\ntelecomunicações com variáveis\ntabulares (ex.: Telco\nCustomer Churn — IBM).\nAlternativas: qualquer dataset\nde classificação binária\ncom ≥ 5.000 registros e ≥ 10\nfeatures.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Dataset público de telecomunicações com variáveis tabulares (ex.: Telco\nCustomer Churn — IBM). Alternativas: qualquer dataset de classificação binária\ncom ≥ 5.000 registros e ≥ 10 features.",
      "autoResize": false,
      "lineHeight": 1.25
    },
