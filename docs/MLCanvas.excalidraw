      "boundElements": [],
      "updated": 1773881095150,
      "link": null,
      "locked": false,
      "text": "Em tempo real com\nfrequência sob demanda\n(cada requisição da API)\n100 - 500 ms\nCPU (baixo custo) \n1-2vCPUs, 2-4 GB RAM",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
