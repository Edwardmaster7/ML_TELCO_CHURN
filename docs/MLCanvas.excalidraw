      "isDeleted": false,
      "boundElements": [],
      "updated": 1773880971846,
      "link": null,
      "locked": false,
      "text": "Prever com antedecedência\nclientes com risco de\ncancelamento \n\no modelo deve ser uma rede\nneural treinada em PyTorch,\ncomparada a baselines do\nScikit-Learn\n\nO resultado esperado é\nchurn=Yes/No",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Prever com antedecedência clientes com risco de cancelamento \n\no modelo deve ser uma rede neural treinada em PyTorch, comparada a baselines do Scikit-Learn\n\nO resultado esperado é churn=Yes/No",
      "autoResize": false,
      "lineHeight": 1.25
    },
