    {
      "id": "3V7Mzeo1XPkvqCREPeDPw",
      "type": "text",
      "x": -334.2972287601987,
      "y": -653.7157709002843,
      "width": 311.880250040725,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
